// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ApiEndpoint {
  id              String     @id @default(cuid())
  monitorId       String?
  name            String
  url             String
  method          String     @default("GET")
  headers         Json?
  body            String?
  expectedStatus  Int        @default(200)
  timeout         Int        @default(5000)
  frequency       Int        @default(86400000)
  status          String     @default("healthy") // healthy | degraded | down
  lastChecked     DateTime?
  avgResponseTime Float?
  uptime          Float      @default(100)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  checks ApiCheck[]
  alerts Alert[]

  @@map("api_endpoints")
}

model ApiCheck {
  id           String   @id @default(cuid())
  apiId        String
  status       Int
  responseTime Float
  success      Boolean
  checkedAt    DateTime @default(now())
  error        String?
  trigger      String   @default("manual") // "cron" | "manual"

  api ApiEndpoint @relation(fields: [apiId], references: [id], onDelete: Cascade)

  alertLogs AlertLog[]

  @@index([apiId, checkedAt])
  @@map("api_checks")
}

model Alert {
  id          String   @id @default(cuid())
  apiId       String
  email       String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  api ApiEndpoint @relation(fields: [apiId], references: [id], onDelete: Cascade)

  logs AlertLog[]

  @@unique([apiId, email])
  @@map("alerts")
}

model AlertLog {
  id        String   @id @default(cuid())
  alertId   String
  checkId   String
  sentAt    DateTime @default(now())
  error     String?

  alert Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  check ApiCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@map("alert_logs")
}
